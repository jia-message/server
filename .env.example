# Server Configuration
PORT=3000
ENV=development # development, production
JIA_MASTER_KEY=your-32-byte-master-key-here-12345 # AES master key for encrypting sensitive config

# Database
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=jia
DB_SSLMODE=disable

# JWT Secret
JWT_SECRET=your-super-secret-jwt-signing-key

# S3-Compatible Storage (configured at setup or via env defaults)
S3_ENDPOINT=localhost:9000
S3_BUCKET=jia-attachments
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_USE_SSL=false

# Push Notifications (if configured)
FCM_CREDENTIALS_JSON=
APNS_KEY_PATH=
APNS_KEY_ID=
APNS_TEAM_ID=
APNS_TOPIC=
